{
  "name": "react-currency-mask",
  "version": "1.3.5",
  "description": "React Input that handles and apply currency masks in your own inputs",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "author": "Leonardo Dias",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "tsc -w",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "tslint -p tsconfig.json",
    "prepare": "yarn build",
    "prepublishOnly": "yarn lint",
    "preversion": "yarn lint",
    "version": "yarn format && git add -A src",
    "postversion": "git push origin main && git push origin main --tags"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.x",
    "@types/react-dom": "^19.x",
    "prettier": "^2.8.1",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^5.8.3"
  },
  "files": [
    "lib/**/*"
  ],
  "keywords": [
    "currency",
    "mask",
    "brl",
    "input",
    "money"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/leoreisdias/react-currency-mask.git"
  },
  "homepage": "https://github.com/leoreisdias/react-currency-mask#readme",
  "bugs": {
    "url": "https://github.com/leoreisdias/react-currency-mask/issues"
  }
}
